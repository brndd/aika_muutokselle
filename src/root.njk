---
permalink: /
layout: false
---

{% set t = translations["fi"] %}
{% set pageTitle = t.page.title %}
{% set pageDescription = t.page.description %}
{% set pageUrl = site.baseUrl ~ locale.lang ~ "/" %}

<!doctype html>
<html lang="fi">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{{ t.page.title }}</title>

    <meta property="og:title" content="{{ t.page.title }}" />
    <meta property="og:description" content="{{ t.page.description }}" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="{{ pageUrl }}" />
    <meta property="og:image" content="{{ site.baseUrl }}preview.png" />
    <meta property="og:image:alt" content="{{ t.page.ogImageAlt }}" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="{{ t.page.title }}" />
    <meta name="twitter:description" content="{{ t.page.description }}" />
    <meta name="twitter:image" content="{{ site.baseUrl }}preview.png" />

    <meta http-equiv="refresh" content="0; url={{ '/en/' | url }}">
    <script>
        (function () {
            var lang = (navigator.language || navigator.userLanguage || "en").toLowerCase();

            if (lang.startsWith("fi")) {
                window.location.replace("{{ '/fi/' | url }}");
            } else if (lang.startsWith("sv")) {
                window.location.replace("{{ '/sv/' | url }}");
            } else {
                window.location.replace("{{ '/en/' | url }}");
            }
        })();
    </script>
  </head>
  <body>
    <p>Redirecting…</p>
    <p><a href="/en/">Continue</a></p>
  </body>
</html>
