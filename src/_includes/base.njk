{% set t = translations[locale.lang] %}
{% set theme = "winter" %}
{% set pageTitle = t.page.title %}
{% set pageDescription = t.page.description %}
{% set pageUrl = site.baseUrl ~ locale.lang ~ "/" %}

<!doctype html>
<html lang="{{ locale.lang }}">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ t.page.title }}</title>

    <meta property="og:title" content="{{ t.page.title }}" />
    <meta property="og:description" content="{{ t.page.description }}" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="{{ pageUrl }}" />
    <meta property="og:image" content="{{ site.baseUrl }}preview.png" />
    <meta property="og:image:alt" content="{{ t.page.ogImageAlt }}" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="{{ t.page.title }}" />
    <meta name="twitter:description" content="{{ t.page.description }}" />
    <meta name="twitter:image" content="{{ site.baseUrl }}preview.png" />

    <script>
        function isDstInFinland(date = new Date()) {
            const year = date.getUTCFullYear();

            function lastSundayOfMonthUTC(monthIndex) {
                const d = new Date(Date.UTC(year, monthIndex + 1, 0, 0, 0, 0));
                const day = d.getUTCDay();
                d.setUTCDate(d.getUTCDate() - day);
                return d;
            }

            const dstStart = lastSundayOfMonthUTC(2);
            dstStart.setUTCHours(1, 0, 0, 0);

            const dstEnd = lastSundayOfMonthUTC(9);
            dstEnd.setUTCHours(1, 0, 0, 0);
            return date >= dstStart && date < dstEnd;
        };
        (function () {
            document.documentElement.dataset.season = isDstInFinland() ? "dst" : "winter";
            document.documentElement.classList.add("js");
        })();
    </script>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>

    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
        integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
        integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

    <link rel="stylesheet" href="/assets/style.css" />
    <link rel="icon"
        href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>☀️</text></svg>">

    <link rel="alternate" hreflang="fi" href="{{ site.baseUrl }}fi/" />
    <link rel="alternate" hreflang="sv" href="{{ site.baseUrl }}sv/" />
    <link rel="alternate" hreflang="en" href="{{ site.baseUrl }}en/" />
</head>

<body>
    <section class="container-fluid pt-3 pb-2">
        <div class="d-flex justify-content-end">
            <div class="d-flex align-items-center lang-group p-2 rounded-pill border bg-white shadow-sm">
                {% for l in locales %}
                <a class="lang-btn{% if l.lang == locale.lang %} active{% endif %}" href="/{{ l.lang }}/"
                    aria-current="{% if l.lang == locale.lang %}page{% endif %}">
                    {{ l.label }}
                </a>
                {% endfor %}
            </div>
        </div>
    </section>

    {{ content | safe }}

    <script src="{{ '/app.js' | url }}"></script>
</body>

</html>